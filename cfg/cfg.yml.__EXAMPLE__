stream_cfg:
  camera_1:
    stream_detector: "rtsp://USER:PASSWORD@192.168.0.24:554/h264/ch01/sub/av_stream"
    stream_video: "rtsp://USER:PASSWORD@192.168.0.24:554/h264/ch01/main/av_stream"
    motion_threshold: 3000
    ai_min_area: 200
  camera_2:
    stream_detector: "rtsp://USER:PASSWORD@192.168.0.25:554/h264/ch01/sub/av_stream"
    stream_video: "rtsp://USER:PASSWORD@192.168.0.25:554/h264/ch01/main/av_stream"
    motion_threshold: 3000
    ai_min_area: 200

# Settings below contain secrets — prefer overriding them via env vars or an untracked
# cfg/cfg.local.yml (see cfg.local.yml.__EXAMPLE__) rather than committing real values here.
archive_sync:
  base_url: ""        # e.g. "https://archive.example.com" — override with env ARCHIVE_BASE_URL
  api_key: ""         # override with env ARCHIVE_API_KEY

control:
  host: "127.0.0.1"
  port: 8090
  token: ""           # override with env CONTROL_API_TOKEN
