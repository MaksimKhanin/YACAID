# Copy to .env (gitignored) and fill in real values, then `docker compose up -d --build`.

# Postgres password for the `yacaid` user / `yacaid_archive` database
POSTGRES_PASSWORD=REPLACE_WITH_RANDOM_LONG_STRING

# Shared secret the recorder's archive_sync client authenticates with (Authorization: Bearer ...)
ARCHIVE_API_KEY=REPLACE_WITH_RANDOM_LONG_STRING

# Used to sign UI session cookies — keep this secret and stable across restarts
SESSION_SECRET=REPLACE_WITH_RANDOM_LONG_STRING

# Recorder's local control API, reachable over an SSH reverse tunnel.
# On the local machine run (see docs/ssh-tunnel.md):
#   autossh -N -R 127.0.0.1:8090:127.0.0.1:8090 tunnel@VPS_IP
# Then set this to the host-gateway address visible inside the Docker container:
CONTROL_BASE_URL=http://host.docker.internal:8090
CONTROL_API_TOKEN=REPLACE_WITH_SAME_TOKEN_AS_RECORDER_CFG

# COOKIE_SECURE controls the Secure flag on the session cookie.
# Browsers silently drop Secure cookies over plain HTTP — set to "false" if you access
# the UI over HTTP (e.g. http://your-server:8001). Set to "true" only when the UI is
# behind an HTTPS reverse proxy (nginx/Caddy/Traefik with a real TLS certificate).
COOKIE_SECURE=false

# Host port the UI is published on
ARCHIVE_SERVER_PORT=8000
